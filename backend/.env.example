# ── AI ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001
MAX_TOKENS=16000

# ── Медиа (картинки/видео) ─────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_...

# ── Авторизация ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=168

# ── База данных (EPIC-01: PostgreSQL + pgvector) ────────────────────────────
# В Docker Compose DATABASE_URL/REDIS_URL задаются автоматически из compose.
# Для локального запуска без Docker укажи свой адрес Postgres:
# DATABASE_URL=postgresql+asyncpg://remtech:remtech@localhost:5432/remtech
POSTGRES_USER=remtech
POSTGRES_PASSWORD=remtech
POSTGRES_DB=remtech
# REDIS_URL=redis://localhost:6379/0

# ── Caddy (HTTPS в ЛВС) ─────────────────────────────────────────────────────
# Адрес сайта для Caddy: домен ЛВС (даст авто-HTTPS) или :80 для проверки.
# SITE_ADDRESS=remtech.local

# ── Документы ───────────────────────────────────────────────────────────────
# Путь к TTF-шрифту с кириллицей для PDF. Оставь пустым для авто-дефолта по ОС.
# PDF_FONT_PATH=C:/Windows/Fonts/arial.ttf
# LOGO_PATH=C:/path/to/logo.png

# ── Сервер ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
